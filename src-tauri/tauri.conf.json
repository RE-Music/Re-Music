{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "RE-Music",
  "version": "1.1.6-1",
  "identifier": "com.remusic.music",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5566",
    "beforeDevCommand": "npm run dev:tauri",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "RE:Music",
        "url": "http://localhost:5566",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' tauri: nmis-proxy: https: data: blob: *; img-src * data: blob:; connect-src *; media-src * data: blob:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/RE-Music/Re-Music/main/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI2OENEQzY0NUNBNjcyRDAKUldUUWNxWmNaTnlNdG1Ta3d3MG1scGdZVnFLSlNFallpM1FyVkZWU3FuWU5xSTBtNERPalZlYlYK"
    }
  }
}